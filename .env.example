### Twox Backend - local dev environment
NODE_ENV=development
PORT=5000

# Public URLs (must be valid URLs; used by config validation)
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_FRONTEND_URL=http://localhost:9000

# Admin panel (Next.js): set ADMIN_BACKEND_INTERNAL_URL to this API’s base + /api (server-only).
# Example: http://127.0.0.1:5000/api or https://api.yourdomain.com/api
# See frontend-admin .env.example (removed insecure NEXT_PUBLIC-only setup for default flow).

# CORS: production player + admin URLs must be listed (FRONTEND_URL / ADMIN_PANEL_FRONTEND_URL are included automatically).
# Add more comma-separated origins if needed (e.g. https://your-app.vercel.app).
# CORS_ALLOWED_ORIGINS=https://preview-xyz.vercel.app,https://admin.vercel.app
# Set to allow any https://*.vercel.app origin (preview deployments):
# ALLOW_VERCEL_PREVIEW_CORS=true

# Database
MONGO_URI=mongodb://localhost:27017/twox

# Auth
# Keep this secret; backend code expects ~45 chars
JWT_SECRET=replace_with_a_long_random_secret_at_least_45_chars
SHARED_SECRET=replace_with_a_long_random_secret

# Admin panel (frontend-admin) login uses Mongo User with role "admin".
# Default dev credentials are created/reset by: npm run seed:admin-user
# (see src/scripts/seed-admin-panel-user.js — run against the same MONGO_URI as this API).

# Email (validation passes if set; can be a dummy value for local dev)
SENDGRID_API_KEY=dummy_sendgrid_key_for_local_dev

# Google OAuth (validation requires these to be set; can be dummy values for local dev)
GOOGLE_OAUTH_CLIENT_ID=dummy-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=dummy-google-oauth-client-secret

# reCAPTCHA (used by backend auth flows)
RECAPTCHA_SECRET_KEY=dummy-recaptcha-secret

# Optional / integrations (leave empty for local dev unless you need them)
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
STEAM_API_KEY=

SKINSBACK_SHOP_ID=
SKINSBACK_SECRET_KEY=

CUSTOMERIO_SITE_ID=
CUSTOMERIO_API_KEY=

NEXUSGGR_API_URL=
NEXUSGGR_AGENT_TOKEN=
NEXUSGGR_AGENT_CODE=
NEXUSGGR_DEMO_API_URL=
NEXUSGGR_DEMO_AGENT_TOKEN=
NEXUSGGR_DEMO_AGENT_CODE=

BLUEOCEAN_API_URL=
BLUEOCEAN_API_USERNAME=
BLUEOCEAN_API_PASSWORD=
BLUEOCEAN_SALT_KEY=

COINSBUY_API_KEY=
COINSBUY_API_SECRET=
COINSBUY_BASE_URL=
COINSBUY_CALLBACK_SECRET=
COINSBUY_WALLET_ID=

VAULTODY_API_KEY=

# -----------------------------------------------------------------------------
# Fystack custody (deposits / withdrawals / webhooks)
# -----------------------------------------------------------------------------
# The "API Credentials Generated" modal only shows FYSTACK_API_KEY + FYSTACK_API_SECRET.
# It does NOT include workspace ID or asset UUIDs — that is normal.
#
# Staging vs production: keys and workspace are tied to one Fystack environment. If you use
# **staging / sandbox** API keys, set FYSTACK_ENV=sandbox. On Render, NODE_ENV=production would
# otherwise default the SDK to Fystack Production and staging keys will fail or hit the wrong API.
# Use FYSTACK_WORKSPACE_ID (and hot wallet / asset map) from the **same** Fystack environment.
#
# FYSTACK_WORKSPACE_ID — Open workspace home (e.g. "Two X Casino") and check the browser URL
#   for a path like /workspaces/<uuid>/... or use Workspace Settings if the UI shows an ID.
#   Required for SDK flows that list wallets / create user deposit wallets (see FystackCustody.service).
#
# FYSTACK_WITHDRAW_ASSET_MAP — You build this: each value is a Fystack "asset_id" for your HOT wallet.
#   With only KEY + SECRET + FYSTACK_HOT_WALLET_ID set in .env, run:
#     npm run fystack:print-assets
#   Map printed rows to keys USDT_ERC20, USDT_TRC20, USDT_BSC, USDC_*, etc. (withdraw rails).
#
# FYSTACK_WEBHOOK_PUBLIC_KEY_HEX — From Fystack webhook / security settings, or try re-running
#   fystack:print-assets after FYSTACK_WORKSPACE_ID is set (script may print API webhook public key).
# -----------------------------------------------------------------------------
# Hot wallet below: Two X Float 1 (from dashboard URL .../wallet/<uuid>).
# -----------------------------------------------------------------------------

# REQUIRED — from Fystack Developers → API Key (public + secret shown once)
FYSTACK_API_KEY=
FYSTACK_API_SECRET=

# REQUIRED for deposits / user wallet creation — NOT on the API key modal (see notes above)
FYSTACK_WORKSPACE_ID=

# Payout / float wallet UUID (send path uses this). Confirmed: Two X Float 1
FYSTACK_HOT_WALLET_ID=51953435-bd5d-48b7-8663-786b794b61f5

# REQUIRED for withdrawals — single-line JSON: Fystack asset UUID per key.
# Keys: SYMBOL_NETWORK e.g. USDT_ERC20, USDT_TRC20, USDT_BSC, USDC_ERC20, ...
# Example (replace values with real asset IDs from Fystack):
# FYSTACK_WITHDRAW_ASSET_MAP={"USDT_ERC20":"<asset-uuid>","USDT_TRC20":"<asset-uuid>","USDT_BSC":"<asset-uuid>","USDC_ERC20":"<asset-uuid>","USDC_TRC20":"<asset-uuid>","USDC_BSC":"<asset-uuid>"}
FYSTACK_WITHDRAW_ASSET_MAP=

# Strongly recommended — Ed25519 webhook verification public key (hex, from Fystack)
FYSTACK_WEBHOOK_PUBLIC_KEY_HEX=

# Optional — comma-separated deposit chains (slug = BLOCKCHAIN_PROTOCOL_NAME enum value).
# Default matches stable withdraw rails: ethereum (ERC20), tron (TRC20), binance-smart-chain (BSC).
# Other Fystack-supported EVM slugs: polygon, arbitrum, optimism, base, linea, avalanche, fantom
FYSTACK_DEPOSIT_BLOCKCHAINS=ethereum,tron,binance-smart-chain

# Optional, unset or non-false = stable-only withdraw UI rails (ERC20/TRC20/BSC)
FYSTACK_UI_STABLECOINS_ONLY=

# Optional — if true, POST /crypto/withdraw submits to Fystack immediately after ledger debit
FYSTACK_AUTO_SUBMIT_WITHDRAW=true

# API environment: production | sandbox | unset (unset + NODE_ENV=production → production SDK env)
# production = live Fystack workspace keys. sandbox = staging / test workspace keys (required for staging creds).
FYSTACK_ENV=production

# Optional, custom API host if Fystack provides one
FYSTACK_API_DOMAIN=

# Optional — SDK debug logging
FYSTACK_DEBUG=false

# NDJSON payment traces (webhook, deposit credit, Fystack submit, admin list, cron) → debug-9131d2.log + ingest
DEBUG_PAYMENT_TRACE=false
