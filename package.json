{
  "name": "bitstake-server",
  "version": "1.0.0",
  "description": "A newly redefined gambling experience!",
  "main": "src/index.js",
  "type": "module",
  "keywords": [
    "crypto",
    "gambling"
  ],
  "scripts": {
    "dev": "nodemon",
    "start": "tsx src/index.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "prettier": "prettier --write 'src/**/*.ts'",
    "seed": "tsx src/seed.js",
    "seed:admin-user": "tsx src/scripts/seed-admin-panel-user.js",
    "init:gameProvider": "node src/scripts/initGameProviders.js",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prepare": "husky install",
    "commit": "git-cz",
    "commit:verify": "git-cz --verify",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "verify": "npm run type-check && npm run build",
    "postinstall": "node scripts/prune-ethers-src.mjs",
    "fystack:print-assets": "tsx src/scripts/print-fystack-wallet-assets.ts",
    "fystack:refresh-assets": "tsx src/scripts/print-fystack-wallet-assets.ts",
    "loadtest:k6:smoke": "k6 run load-tests/k6/smoke.js",
    "loadtest:k6:webhook": "k6 run load-tests/k6/fystack-webhook-pending.js",
    "loadtest:k6:mixed": "k6 run load-tests/k6/fystack-webhook-mixed.js"
  },
  "author": "BitStake",
  "license": "UNLICENSED",
  "engines": {
    "node": "^20.18.1"
  },
  "_moduleAliases": {
    "@": "src",
    "@utils": "src/utils"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@bountyscripts/express-middleware": "^1.0.0",
    "@coinbase/coinbase-sdk": "^0.13.0",
    "@faker-js/faker": "^9.3.0",
    "@fystack/sdk": "^0.1.14",
    "@getbrevo/brevo": "^3.0.1",
    "@sendgrid/mail": "^8.1.4",
    "@solana/web3.js": "^1.98.0",
    "agenda": "^5.0.0",
    "async": "^3.2.6",
    "axios": "^1.6.7",
    "base64-stream": "^1.0.0",
    "bcrypt": "^6.0.0",
    "bufferutil": "^4.0.8",
    "chance": "^1.1.11",
    "coinbase": "^2.0.8",
    "coinpayments": "^2.1.0",
    "coinpayments-ipn": "^1.0.0",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "country-list": "^2.3.0",
    "crypto": "^1.0.1",
    "crypto-browserify": "^3.12.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "eosjs": "^22.1.0",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "express-useragent": "^1.0.15",
    "express-validator": "^7.0.1",
    "formidable": "^3.5.4",
    "geoip-lite": "^1.4.10",
    "globals": "^15.14.0",
    "googleapis": "^133.0.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "module-alias": "^2.2.3",
    "moment": "^2.30.1",
    "mongoose": "^8.1.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-steam-openid": "^1.2.1",
    "nodemailer": "^6.9.9",
    "nodemon": "^3.1.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "querystring": "^0.2.1",
    "random-seed": "^0.3.0",
    "rate-limiter-flexible": "^7.1.0",
    "seedrandom": "^3.0.5",
    "serve-favicon": "^2.5.0",
    "skinsback-sdk": "^0.2.12",
    "socket.io": "^4.7.4",
    "speakeasy": "^2.0.0",
    "tweetnacl": "^1.0.3",
    "twilio": "^4.22.0",
    "utf-8-validate": "^5.0.10",
    "uuid": "^9.0.1",
    "wallet-address-validator": "^0.2.4",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@commitlint/cli": "^16.3.0",
    "@commitlint/config-conventional": "^16.2.4",
    "@esbuild-kit/esm-loader": "^2.6.5",
    "@jest/globals": "^29.7.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-config-prettier": "^8.10.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "lint-staged": "^12.5.0",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "**/*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
