# Copy values into GitHub Actions env (or a local shell) for integration / smoke runs.
# See .github/workflows/ci.yml job "integration".
# With Mongo listening on MONGO_URI:  npm run ci:integration

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/twox_ci
BACKEND_URL=http://127.0.0.1:5000
FRONTEND_URL=http://127.0.0.1:3000
ADMIN_PANEL_FRONTEND_URL=http://127.0.0.1:9000
JWT_SECRET=replace_with_a_long_random_secret_at_least_45_chars
SHARED_SECRET=replace_with_a_long_random_secret
SENDGRID_API_KEY=dummy_sendgrid_key_for_local_dev
GOOGLE_OAUTH_CLIENT_ID=dummy-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=dummy-google-oauth-client-secret
RECAPTCHA_SECRET_KEY=dummy-recaptcha-secret
ADMIN_SECRET=replace_with_a_long_random_admin_secret

# Optional: trim socket namespaces in CI (see socket-server.js envDisableKey names)
# PRICE_SOCKET_SERVICE_DISABLE=1
# CHAT_SOCKET_SERVICE_DISABLE=1
