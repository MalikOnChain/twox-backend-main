{
  "eslint.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.alwaysShowStatus": true,
  "css.validate": false,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "cSpell.words": [
    "Bitstake",
    "blueocean",
    "cashout",
    "dogecoin",
    "fiverscan",
    "gamelists",
    "gameproviders",
    "gifs",
    "giphy",
    "holesky",
    "litecoin",
    "mailgun",
    "mordor",
    "nexusggr",
    "skinsback",
    "solana",
    "sumsub",
    "tuabet",
    "vaultody",
    "wagerd"
  ]
}
